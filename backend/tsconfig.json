{
  "compilerOptions": {
    "rootDir": "./src",
    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "dist", // inside dist new compiled files will be created 
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*.ts", "src/index.ts"]
}
